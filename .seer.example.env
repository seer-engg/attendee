DJANGO_SETTINGS_MODULE=attendee.settings.seer_production

DJANGO_SECRET_KEY=change-me-to-a-secure-random-string
CREDENTIALS_ENCRYPTION_KEY=change-me-generate-with-python-fernet

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME
POSTGRES_SSL_REQUIRE=false

REDIS_URL=redis://redis:6379/5
# For TLS Redis use:
# REDIS_URL=rediss://YOUR_REDIS_USER:YOUR_REDIS_PASSWORD@YOUR_REDIS_HOST:6379/5
# REDIS_SSL_REQUIREMENTS=required

LAUNCH_BOT_METHOD=celery
ENABLE_CHROME_SANDBOX=false

SITE_DOMAIN=meetingbot-dev.getseer.dev
CSRF_TRUSTED_ORIGINS=https://meetingbot-dev.getseer.dev

AWS_RECORDING_STORAGE_BUCKET_NAME=your-s3-bucket
AWS_AUDIO_CHUNK_STORAGE_BUCKET_NAME=your-s3-bucket
AWS_DEFAULT_REGION=us-east-1
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_ACCESS_KEY_ID=your-aws-access-key
# Optional for S3-compatible providers only
# AWS_ENDPOINT_URL=
USE_REMOTE_STORAGE_FOR_AUDIO_CHUNKS=false

DISABLE_EMAIL=true
DISABLE_SIGNUP=false
DEFAULT_FROM_EMAIL=noreply@localhost

ATTENDEE_LOG_LEVEL=INFO
ATTENDEE_LOG_FORMAT=
SENTRY_DSN=

CHARGE_CREDITS_FOR_BOTS=false
REQUIRE_HTTPS_WEBHOOKS=false

DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me

COMPOSE_PROJECT_NAME=seer-dev
